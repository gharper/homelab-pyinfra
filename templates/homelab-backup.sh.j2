#!/bin/bash
# Homelab backup script
# Generated by pyinfra
# Host: {{ host.name }}
# Role: {{ host.data.get('role', 'unknown') }}

set -e

LOG_FILE="/var/log/homelab/backup/backup-$(date +%Y%m%d-%H%M%S).log"
BACKUP_RETENTION_DAYS={{ host.data.get('backup_retention_days', 30) }}

echo "=======================================" | tee -a "$LOG_FILE"
echo "Starting backup at $(date)" | tee -a "$LOG_FILE"
echo "Host: {{ host.name }}" | tee -a "$LOG_FILE"
echo "=======================================" | tee -a "$LOG_FILE"

# Cleanup old backup logs
find /var/log/homelab/backup/ -name "backup-*.log" -mtime +${BACKUP_RETENTION_DAYS} -delete 2>/dev/null || true

# Add your backup commands here
# Examples:

# Backup important directories
# rsync -avz /etc/ /backups/{{ host.name }}/etc/
# rsync -avz /home/ /backups/{{ host.name }}/home/

# Backup to remote server
# rsync -avz -e ssh /important/data/ backup-server:/backups/{{ host.name }}/

# Backup using borgbackup
# borg create --stats --compression lz4 \
#   /backups/borg::{{ host.name }}-{now:%Y-%m-%d-%H%M} \
#   /etc /home /var/log

# Database backups
# mysqldump --all-databases | gzip > /backups/{{ host.name }}/mysql-$(date +%Y%m%d).sql.gz

# Docker volumes backup (if Docker is enabled)
{% if host.data.get('docker_enabled', False) %}
# docker run --rm -v /var/lib/docker/volumes:/volumes \
#   -v /backups/{{ host.name }}:/backup \
#   alpine tar czf /backup/docker-volumes-$(date +%Y%m%d).tar.gz /volumes
{% endif %}

echo "=======================================" | tee -a "$LOG_FILE"
echo "Backup completed at $(date)" | tee -a "$LOG_FILE"
echo "=======================================" | tee -a "$LOG_FILE"

# Send notification (optional)
# echo "Backup completed on {{ host.name }}" | mail -s "Backup Success" admin@example.com
